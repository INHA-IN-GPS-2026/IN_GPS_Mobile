<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.IN_GPS" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="android:windowBackground">@color/color_surface</item>
    </style>

    <style name="Theme.IN_GPS" parent="Base.Theme.IN_GPS" />

    <!-- Card style -->
    <style name="Widget.INGPS.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/color_card_bg</item>
    </style>

    <!-- Pill button -->
    <style name="Widget.INGPS.Button.Pill" parent="Widget.Material3.Button">
        <item name="cornerRadius">26dp</item>
        <item name="backgroundTint">@color/color_primary</item>
    </style>
</resources>
